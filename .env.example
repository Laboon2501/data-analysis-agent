# Data Analysis Agent local configuration example.
# Copy to a local .env if your own tooling loads it. Do not commit real secrets.

# Runtime backend. Keep memory for default local development and CI-like checks.
DATA_ANALYSIS_AGENT_RUNNER_BACKEND=memory
DATA_ANALYSIS_AGENT_API_HOST=127.0.0.1
DATA_ANALYSIS_AGENT_API_PORT=8000
DATA_ANALYSIS_AGENT_API_RELOAD=false

# Datasource. Use either a SQLite file path or a SQLAlchemy URL.
DATA_ANALYSIS_AGENT_DATASOURCE_URL=demo/ecommerce_demo.sqlite
DATA_ANALYSIS_AGENT_DATASOURCE_ID=ecommerce-demo-sqlite

# Artifact storage. Celery mode should use a shared file artifact directory.
DATA_ANALYSIS_AGENT_ARTIFACT_DIR=artifacts

# File datasource uploads. Local path registration is disabled by default.
DATA_ANALYSIS_AGENT_UPLOAD_DIR=uploads
DATA_ANALYSIS_AGENT_MAX_UPLOAD_MB=25
DATA_ANALYSIS_AGENT_ALLOW_LOCAL_FILE_PATHS=false

# User-visible session history. Keep memory for temporary local runs.
# Use sqlite/sqlalchemy only when DATA_ANALYSIS_AGENT_SESSION_DB_URL is set.
DATA_ANALYSIS_AGENT_SESSION_STORE=memory
DATA_ANALYSIS_AGENT_SESSION_DB_URL=
DATA_ANALYSIS_AGENT_SESSION_TTL_DAYS=
DATA_ANALYSIS_AGENT_SESSION_MAX_MESSAGES=

# Redis / Celery / checkpoint settings for optional local distributed runtime.
# Leave blank unless running docker-compose services locally.
DATA_ANALYSIS_AGENT_REDIS_URL=
DATA_ANALYSIS_AGENT_CELERY_BROKER_URL=
DATA_ANALYSIS_AGENT_CELERY_RESULT_BACKEND=
DATA_ANALYSIS_AGENT_CELERY_QUEUE=data-analysis-agent
DATA_ANALYSIS_AGENT_CELERY_TASK_NAME=app.workers.celery_tasks.run_agent_job
DATA_ANALYSIS_AGENT_DATABASE_URL=
DATA_ANALYSIS_AGENT_CHECKPOINT_URL=
DATA_ANALYSIS_AGENT_POSTGRES_URL=

# Optional memory backend external stores.
DATA_ANALYSIS_AGENT_USE_REDIS_STORES=false
DATA_ANALYSIS_AGENT_USE_POSTGRES_CHECKPOINT=false
DATA_ANALYSIS_AGENT_USE_FILE_ARTIFACT_STORE=false

# Optional LLM provider placeholders. Store the real key in the named env var.
DATA_ANALYSIS_AGENT_LLM_PROVIDER=
DATA_ANALYSIS_AGENT_LLM_MODEL=
DATA_ANALYSIS_AGENT_LLM_BASE_URL=
DATA_ANALYSIS_AGENT_LLM_API_KEY_ENV=

# Product Web UI local LLM config. The saved config file is local-only and ignored by git.
DATA_ANALYSIS_AGENT_LLM_CONFIG_PATH=runtime/llm_config.json
DATA_ANALYSIS_AGENT_LLM_ENABLED_NODES=
